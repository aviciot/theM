# ============================================================
# Odin — Multi-Agent Orchestration Platform
# Environment configuration template
#
# Copy to .env and fill in all required values before starting.
# [REQUIRED] vars must be changed — defaults are insecure.
#
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Credentials for odin-postgres container
ODIN_DB_USER=odin
ODIN_DB_PASSWORD=change-this-db-password        # [REQUIRED]

# ─── Security ─────────────────────────────────────────────────────────────────
# odin-bridge: Fernet/signing key
ODIN_SECRET_KEY=change-this-secret-key          # [REQUIRED] min 32 chars
# odin-auth-service: JWT signing key
ODIN_JWT_SECRET=change-this-jwt-secret          # [REQUIRED] min 32 chars
# odin-redis: optional password (leave blank for no auth on private network)
ODIN_REDIS_PASSWORD=

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                     # [REQUIRED]
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Network / Traefik ────────────────────────────────────────────────────────
ODIN_HOSTNAME=odin.example.com                  # [REQUIRED] your domain
ODIN_CORS_ORIGINS=https://odin.example.com

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ─── Internal (set by docker-compose, usually no need to change) ──────────────
# DATABASE_HOST=odin-postgres
# DATABASE_PORT=5432
# DATABASE_NAME=odin
# DATABASE_USER=${ODIN_DB_USER}
# DATABASE_PASSWORD=${ODIN_DB_PASSWORD}
# REDIS_HOST=odin-redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_SSL=false
# REDIS_ENABLED=true
# AUTH_SERVICE_URL=http://odin-auth-service:8701
# LOG_FORMAT=json
