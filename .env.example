# ============================================================
# the-M — Multi-Agent Orchestration Platform
# Environment configuration template
#
# Copy to .env and fill in all required values before starting.
# [REQUIRED] vars must be changed — defaults are insecure.
#
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ─── Database ─────────────────────────────────────────────────────────────────
THE_M_DB_USER=them
THE_M_DB_PASSWORD=change-this-db-password        # [REQUIRED]

# ─── Security ─────────────────────────────────────────────────────────────────
# them-bridge: Fernet/signing key
THE_M_SECRET_KEY=change-this-secret-key          # [REQUIRED] min 32 chars
# them-auth-service: JWT signing key
THE_M_JWT_SECRET=change-this-jwt-secret          # [REQUIRED] min 32 chars
# them-redis: optional password (leave blank for no auth on private network)
THE_M_REDIS_PASSWORD=

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                     # [REQUIRED]
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Security Scanner (agents/security_scanner) ──────────────────────────────
SECURITY_SCANNER_ANTHROPIC_API_KEY=                 # Falls back to ANTHROPIC_API_KEY if blank

# ─── Vision Agent (agents/vision_agent) ──────────────────────────────────────
GOOGLE_MAPS_API_KEY=                             # Google Cloud: Geocoding API + Street View Static API
FAL_API_KEY=                                     # fal.ai: FLUX.1 Kontext Pro (~$0.055/image)

# ─── Network / Traefik ────────────────────────────────────────────────────────
THE_M_HOSTNAME=them.example.com                  # [REQUIRED] bridge API + WS hostname
THE_M_UI_HOSTNAME=them-ui.example.com            # [REQUIRED] frontend UI hostname
THE_M_CORS_ORIGINS=https://them-ui.example.com

# Browser-facing WebSocket URL for the bridge (used by playground UI).
# Dev:        ws://localhost:8001
# Production: wss://them.example.com
THE_M_BRIDGE_WS_URL=wss://them.example.com

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ─── Voice / LiveKit ─────────────────────────────────────────────────────────
# Generated automatically by generate-env.sh / generate-env.ps1 from master secret.
# Required when running: docker compose --profile voice up -d livekit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_PUBLIC_URL=ws://localhost:8088/livekit

# ─── Internal (set by docker-compose, usually no need to change) ──────────────
# DATABASE_HOST=them-postgres
# DATABASE_PORT=5432
# DATABASE_NAME=them
# DATABASE_USER=${THE_M_DB_USER}
# DATABASE_PASSWORD=${THE_M_DB_PASSWORD}
# REDIS_HOST=them-redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_SSL=false
# REDIS_ENABLED=true
# AUTH_SERVICE_URL=http://them-auth-service:8701
# LOG_FORMAT=json
