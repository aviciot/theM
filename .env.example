# Odin — environment variables
# Copy to .env and fill in real values

# Application
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8001
ODIN_INSTANCE_ID=bridge-1

# Database (shares omni-postgres container, separate DB)
DATABASE_HOST=omni-pgbouncer
DATABASE_PORT=5432
DATABASE_NAME=odin
DATABASE_USER=odin
DATABASE_PASSWORD=change_me

# Redis (shares omni-redis, DB index 1)
REDIS_HOST=omni-redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_ENABLED=true

# Auth service
AUTH_SERVICE_URL=http://odin-auth-service:8701

# Security (Fernet key derivation)
SECRET_KEY=change-this-to-a-long-random-string-in-production

# LLM
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS
CORS_ORIGINS=http://localhost:3111

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
