# ============================================================
# the-M — Linux deployment environment template
#
# Copy to .env and fill in ALL [REQUIRED] values before deploying.
# Generate secrets:  openssl rand -hex 32
# Or use:            ./generate-env.sh  (reads secrets.local)
#
# This file documents every variable the Linux stack consumes.
# On Windows development, .env.example is used instead.
# ============================================================

# ─── Database ─────────────────────────────────────────────────────────────────
THE_M_DB_USER=them
THE_M_DB_PASSWORD=CHANGE_ME_db_password           # [REQUIRED] strong random value

# ─── Security ─────────────────────────────────────────────────────────────────
THE_M_SECRET_KEY=CHANGE_ME_secret_key             # [REQUIRED] min 32 chars
THE_M_JWT_SECRET=CHANGE_ME_jwt_secret             # [REQUIRED] min 32 chars
THE_M_REDIS_PASSWORD=                             # optional — leave blank for private network

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                      # [REQUIRED]
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Agent-specific API keys ──────────────────────────────────────────────────
DOCU_WRITER_ANTHROPIC_API_KEY=                    # falls back to ANTHROPIC_API_KEY
DEBATE_ANTHROPIC_API_KEY=                         # falls back to ANTHROPIC_API_KEY
SECURITY_SCANNER_ANTHROPIC_API_KEY=               # falls back to ANTHROPIC_API_KEY

# ─── Network ─────────────────────────────────────────────────────────────────
# On Linux the stack listens on 0.0.0.0:8088. Set THE_M_HOSTNAME if you have
# a domain name and want Host-based routing in Traefik.
THE_M_HOSTNAME=                                   # e.g. them.internal — leave blank for PathPrefix-only
THE_M_UI_HOSTNAME=                                # e.g. them-ui.internal
THE_M_CORS_ORIGINS=http://localhost:8088

# Browser-facing WebSocket URL. On Linux servers set this to the server's IP or DNS.
# e.g. ws://192.168.1.10:8088  or  wss://them.example.com
THE_M_BRIDGE_WS_URL=ws://localhost:8088

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ─── Go Gateway — Phase 11c event transport ───────────────────────────────────
# pubsub:  production default — Pub/Sub only (safe, no Streams)
# dual:    Streams + Pub/Sub in parallel — for staging validation
# streams: Streams only — only after explicit approval (Phase 11c-D gate)
RUN_EVENTS_MODE=pubsub

# ─── Temporal ─────────────────────────────────────────────────────────────────
# Temporal is included in the temporal profile. No external Temporal needed.
# TEMPORAL_HOST_PORT is internal (temporal-frontend:7233) — set only for test runners.
TEMPORAL_HOST_PORT=temporal-frontend:7233

# ─── Voice / LiveKit (optional) ───────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_PUBLIC_URL=ws://localhost:8088/livekit

# ─── Vision Agent (optional) ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
FAL_API_KEY=

# ─── Go bridge reconciler ─────────────────────────────────────────────────────
# Keep true until reconciler is validated on this environment.
RECONCILER_DRY_RUN=true
